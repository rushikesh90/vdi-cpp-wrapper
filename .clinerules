# Project: vdi_wrapper
# Description: This file documents the high‑level code structure and the
# responsibilities of each component in the VDI wrapper project.

# 1. include/vdi_client.h
#    - Provides the VdiClient class interface.
#    - On Windows builds includes <windows.h>, <sqlvdi.h>, and <combaseapi.h>.
#    - Defines a placeholder implementation for non‑Windows platforms to allow
#      compilation without the actual VDI SDK.
#    - Exposes:
#        * IClientVirtualDeviceSet2* device_set_;
#        * bool connect(const std::wstring&, int);
#        * bool open_devices();
#        * bool get_next_chunk(uint8_t*&, size_t&);
#        * void complete_chunk();
#        * void close();
#        * void process_commands();        // Main command loop (added 2026-05-14)
#    - Private:
#        * void handle_command(IClientVirtualDevice*, VDC_Command*);
#        * Destructor releases COM object and calls CoUninitialize() on Windows.

# 2. src/vdi_client.cpp
#    - Implements VdiClient.
#    - Windows path:
#        * Calls CoInitializeEx(COINIT_MULTITHREADED).
#        * Uses CoCreateInstance to obtain CLSID_MSSQL_ClientVirtualDeviceSet.
#        * Configures VDConfig and calls device_set_->CreateEx().
#        * Returns true on success.
#    - Non‑Windows path:
#        * Returns true as a stub.
#    - process_commands() (added 2026-05-14):
#        * Loops over all open devices calling GetCommand(INFINITE, &cmd).
#        * Processes each command via handle_command().
#        * Terminates on VD_E_CLOSE from GetCommand (the real VDI close signal)
#          OR on VDC_Close sentinel command code.
#    - handle_command() (added 2026-05-14):
#        * Switch on cmd->commandCode for VDC_Read, VDC_Write, VDC_Flush,
#          VDC_ClearError, VDC_Close.
#        * Calls CompleteCommand with 4 args: (cmd, ERROR_SUCCESS, size, position).
#          CRITICAL: CompleteCommand takes 4 parameters (not 2 as in some pseudocode).
#          Wrong signature causes compile error or stack corruption.

# 3. include/backup_request.h
#    - Defines BackupRequest struct with database name, backup type,
#      device count, buffer size, and device name.

# 4. include/backup_engine.h / src/backup_engine.cpp
#    - BackupEngine orchestrates a backup session.
#    - start_backup():
#        * Creates a VdiClient instance.
#        * Calls client->connect() with request parameters.
#        * Creates a NullSink (placeholder sink implementation).
#        * Constructs BackupSession with the client and sink.
#        * Runs the session.

# 5. src/main.cpp
#    - Entry point for the application.
#    - Currently uses VdiClient directly (2026-05-14 refactor):
#        * Generates a unique VDI device name with process ID suffix.
#        * Calls client.connect() then client.open_devices().
#        * Prints instructions for the T-SQL BACKUP command the user must run.
#        * Calls client.process_commands() to handle the backup data flow.
#    - Previously used BackupEngine/BackupRequest (see backup_engine.cpp for that path).

# 6. include/sqlvdi_guids.h
#    - Declares CLSID_MSSQL_ClientVirtualDeviceSet and IID_IClientVirtualDeviceSet2
#      using EXTERN_C const with <guiddef.h>.
#    - Can be included from any file that needs these GUID symbols.

# 7. src/sqlvdi_guids.cpp
#    - Defines the GUIDs via DEFINE_GUID() under #define INITGUID.
#    - Only file in the project that ever #defines INITGUID, preventing
#      multiple-definition linker errors.
#    - Replaces the old sqlvdi.cpp which used brace initialization instead
#      of the standard Windows DEFINE_GUID/INITGUID pattern.

# 8. CMakeLists.txt
#    - Sets C++17 standard.
#    - Includes the 'include' directory.
#    - Builds the vdi_wrapper executable from the source files:
#        * src/main.cpp
#        * src/vdi_client.cpp
#        * src/backup_engine.cpp
#        * src/backup_session.cpp
#        * src/sink.cpp
#        * src/sqlvdi_guids.cpp     (was sqlvdi.cpp prior to GUID refactor)
#    - Links against ole32.lib (required for COM on Windows).

# 9. Build notes
#    - On Windows, the project must be built with a compiler that can locate
#      the VDI SDK headers (vdi.h) and libraries.
#    - On non‑Windows platforms the placeholder definitions allow the code to
#      compile, but the VDI functionality will be a no‑op.
#    - CMake build is currently non-functional on this machine (2026-05-14).
#      Use manual MSVC cl.exe commands (see section 11a) instead.

# 10. GUID Architecture (refactored 2026-05-09, IID corrected 2026-05-13)
#     - GUIDs are declared in include/sqlvdi_guids.h (EXTERN_C const with <guiddef.h>)
#       and defined in src/sqlvdi_guids.cpp (single #define INITGUID + DEFINE_GUID).
#     - This avoids:
#         * Multiple-definition linker errors (only one .cpp ever defines INITGUID)
#         * Header pollution (consumers only see extern declarations)
#         * Fragile brace-initialization (the old sqlvdi.cpp approach)
#     - GUID values (CRITICAL: IID and CLSID are DIFFERENT GUIDs):
#         CLSID_MSSQL_ClientVirtualDeviceSet = {0x40700425,0x0080,0x11d2,{0x85,0x1f,0x00,0xc0,0x4f,0xc2,0x17,0x59}}
#         IID_IClientVirtualDeviceSet2        = {0xd0e6eb07,0x7a62,0x11d2,{0x85,0x73,0x00,0xc0,0x4f,0xc2,0x17,0x59}}
#         IID_IClientVirtualDevice            = {0x40700424,0x0080,0x11d2,{0x85,0x1f,0x00,0xc0,0x4f,0xc2,0x17,0x59}}
#         IID_IClientVirtualDeviceSet         = {0x40700425,0x0080,0x11d2,{0x85,0x1f,0x00,0xc0,0x4f,0xc2,0x17,0x59}}

# 10a. CreateEx Signature Fix (critical 2026-05-13)
#      - WRONG: CreateEx(LPCWSTR lpName, VDConfig* pConfig) - TWO parameters
#      - RIGHT: CreateEx(LPCWSTR lpInstanceName, LPCWSTR lpName, VDConfig* pConfig) - THREE parameters
#      - First parameter is the SQL Server instance name (nullptr for default instance)
#      - Calling with wrong signature causes VD_E_NOTSUPPORTED (0x80770009)
#      - Fixed in include/sqlvdi.h and src/vdi_client.cpp

# 10b. VDConfig Structure Complete Definition (critical 2026-05-13)
#      - WRONG: Only 3 fields (deviceCount, features, commandTimeout)
#      - RIGHT: 11 fields as per MS SQL Server VDI specification
#      All required fields:
#        - deviceCount: Number of virtual devices
#        - features: Feature flags (VDF_Default = 0)
#        - prefixZoneSize: Prefix zone size (typically 0 for basic backup)
#        - alignment: Buffer alignment (0 = use default)
#        - softFileMarkBlockSize: Soft file mark block size (0 = default)
#        - EOMWarningSize: End-of-media warning threshold (0 = disabled)
#        - serverTimeOut: Server timeout in milliseconds (60000 = 60 seconds)
#        - blockSize: Logical block size (0 = use default)
#        - maxIODepth: Maximum I/O queue depth (0 = unlimited)
#        - maxTransferSize: Maximum transfer size (0 = unlimited)
#        - bufferAreaSize: Total buffer area size (0 = use default)
#      - Incomplete structure causes VD_E_INVALID (0x80770006)
#      - Fixed by initializing all 11 fields to appropriate values
#      - See Microsoft samples: github.com/microsoft/sql-server-samples/blob/master/samples/features/sqlvdi/include/vdi.h

# 10c. IClientVirtualDeviceSet2 Vtable Layout Fix (CRITICAL 2026-05-13)
#      - ROOT CAUSE of "Run-Time Check Failure: ESP not properly saved" error
#      - WRONG: interface IClientVirtualDeviceSet2 : public IUnknown
#        (only 3 vtable entries before CreateEx -> CreateEx at slot 3, but actual
#         implementation expects it at slot 11)
#      - RIGHT: interface IClientVirtualDeviceSet2 : public IClientVirtualDeviceSet
#        (inherits 8 methods from IClientVirtualDeviceSet + QI/AddRef/Release
#         -> CreateEx at slot 11 matches actual COM implementation)
#      - The real VDI interface chain is:
#        IUnknown -> IClientVirtualDeviceSet (8 methods) -> IClientVirtualDeviceSet2 (2 methods)
#      - Wrong vtable offset causes mismatched stack cleanup -> ESP corruption -> RTC failure
#      - Fixed in include/sqlvdi.h

# 10d. VDI Protocol Flow (2026-05-13)
#      - Proper sequence documented in src/vdi_client.cpp:
#        1. CoCreateInstance(CLSID, IID_IClientVirtualDeviceSet2)
#        2. device_set_->CreateEx(nullptr, lpName, &config)
#        3. device_set_->GetConfiguration(timeout, &server_config)
#           - BLOCKS waiting for SQL Server to connect via T-SQL:
#             BACKUP DATABASE [db] TO VIRTUAL_DEVICE = N'<name>'
#           - Fails with VD_E_TIMEOUT (0x80770003) after timeout if no SQL Server connects
#        4. device_set_->OpenDevice(name, &device) - for each device
#           - The device name must match the T-SQL VIRTUAL_DEVICE name EXACTLY
#           - DO NOT append ":<index>" - use the base name directly
#           - OpenDevice called before GetConfiguration fails with VD_E_OBJECT (0x8077000c)
#           - After OpenDevice succeeds, the command loop MUST start immediately
#        5. device->GetCommand(INFINITE, &cmd) - blocks for SQL Server commands
#        6. Process command (VDC_Write, VDC_Flush, VDC_ClearError, etc.)
#        7. device->CompleteCommand(cmd, status, bytes, position) -- MUST be 4 args!
#        8. Repeat steps 5-7 until GetCommand returns VD_E_CLOSE (0x80770001).
#      - SQL Server IO error 995 = The I/O operation has been aborted
#        This means VDI client dropped the connection (exited without completing
#        commands or entering the command loop).

# 10e. Command Loop Architecture (added 2026-05-14)
      - VdiClient::process_commands() implements the main command loop.
      - VdiClient::handle_command() dispatches each command.
      - Close detection uses TWO mechanisms (belt-and-suspenders):
        1. GetCommand returning FAILED(hr) with hr == VD_E_CLOSE (0x80770001).
           This is the REAL close signal in the VDI protocol.
        2. VDC_Close sentinel (99) command code for internal signaling.
      - CRITICAL: CompleteCommand takes 4 parameters:
          (cmd, dwCompletionCode, dwBytesTransferred, dwlPosition)
        NOT 2 parameters as sometimes shown in pseudocode.
        Wrong signature won't compile (or causes stack corruption if it does).
      - VDI error codes defined in include/sqlvdi.h:
        VD_E_CLOSE        = 0x80770001 (normal session end)
        VD_E_TIMEOUT      = 0x80770003 (no SQL Server connection)
        VD_E_OBJECT       = 0x8077000c (wrong order of operations)
        VD_E_NOTSUPPORTED = 0x80770009 (bad parameters)
        VD_E_INVALID      = 0x80770006 (bad VDConfig)
        VD_E_ABORT        = 0x80770004 (aborted)
        VD_E_OPEN         = 0x80770002 (open failed)

# 10f. Throughput Instrumentation (added 2026-05-14)
      - process_commands() records std::chrono::steady_clock::now() start
        before entering the command loop.
      - After the loop exits (via VD_E_CLOSE, VD_E_EOF, or VDC_Close command
        code), the elapsed wall-clock time is computed.
      - Throughput is printed as:
          Throughput:   X.XXXXX MB/s
        where MB/s = (total_bytes_ / 1024.0 / 1024.0) / seconds.
      - This works for ALL close paths – not just the VDC_Close command code.
      - See vdi_client.cpp process_commands().
      - CRITICAL: In the VD_E_CLOSE / VD_E_EOF branch, cmd is NULL so we must
        NOT call handle_command(device, cmd) – doing so would dereference NULL.
        Instead we simply log the message and break out of the loop.

# 11. Reference: Official Microsoft VDI Header
#     - include/vdi_real.h is the official MIDL-generated vdi.h from Microsoft's
#       SQL Server samples repository
#     - Downloaded from:
#       https://raw.githubusercontent.com/microsoft/sql-server-samples/master/samples/features/sqlvdi/include/vdi.h
#     - Contains the complete interface definitions for all 6 VDI interfaces:
#       IClientVirtualDevice, IClientVirtualDeviceSet, IClientVirtualDeviceSet2,
#       IServerVirtualDevice, IServerVirtualDeviceSet, IServerVirtualDeviceSet2
#     - Also defines CLSID_MSSQL_ClientVirtualDeviceSet as an alias for IID_IClientVirtualDeviceSet
#     - The project's include/sqlvdi.h is a simplified version that only declares
#       the client-side interfaces needed by this wrapper

# 11a. VDI COM Registration Test
#     - Confirmed (2026-05-09): CLSID_MSSQL_ClientVirtualDeviceSet
#       ({40700425-0080-11d2-851f-00c04fc21759}) IS registered on this machine.
#       CoCreateInstance returns SUCCESS.
#     - Compilation commands (MSVC x64, run from repo root):
#       $env:Path = "C:\Program Files\Microsoft Visual Studio\18\Community\VC\Tools\MSVC\14.50.35717\bin\Hostx64\x64;" + $env:Path;
#       $env:INCLUDE = "C:\Program Files\Microsoft Visual Studio\18\Community\VC\Tools\MSVC\14.50.35717\include;C:\Program Files (x86)\Windows Kits\10\Include\10.0.26100.0\ucrt;C:\Program Files (x86)\Windows Kits\10\Include\10.0.26100.0\um;C:\Program Files (x86)\Windows Kits\10\Include\10.0.26100.0\shared;C:\Users\azureuser\source\repos\rushikesh90\vdi-cpp-wrapper\include";
#       $env:LIB = "C:\Program Files\Microsoft Visual Studio\18\Community\VC\Tools\MSVC\14.50.35717\lib\x64;C:\Program Files (x86)\Windows Kits\10\Lib\10.0.26100.0\ucrt\x64;C:\Program Files (x86)\Windows Kits\10\Lib\10.0.26100.0\um\x64";
#       cl src\sqlvdi_guids.cpp /c /EHsc /std:c++17 /Fosqlvdi_guids.obj   # GUID definition compile test
#       cl src\vdi_client.cpp /c /EHsc /std:c++17 /Fovdi_client.obj       # Consumer compile test
#       cl src\main.cpp /c /EHsc /std:c++17 /Fomain.obj                   # Main compile
#       link main.obj vdi_client.obj sqlvdi_guids.obj /OUT:vdi_wrapper.exe ole32.lib /SUBSYSTEM:CONSOLE
#     - Key detail: only the single definition file (sqlvdi_guids.cpp) places
#       `#define INITGUID` BEFORE any includes; all other files consume the
#       EXTERN_C const declarations from sqlvdi_guids.h without INITGUID.
#
# 12. CMake CLI build and clean rules
#     - Configure the build tree from the repo root:
#         cmake -S . -B build -DCMAKE_BUILD_TYPE=Debug
#     - Build the default target:
#         cmake --build build --config Debug
#     - Build release:
#         cmake --build build --config Release
#     - Clean the build tree:
#         cmake --build build --target clean --config Debug
#       or for multi-config projects:
#         cmake --build build --target clean --config Release
#     - Install the built executable (optional):
#         cmake --install build --config Release
#     - The generated binary will be placed in:
#         build/bin/<Config>/vdi_wrapper.exe
#       for example build/bin/Debug/vdi_wrapper.exe or build/bin/Release/vdi_wrapper.exe
#     - For a single-config generator on non-Windows platforms,
#       omit `--config <type>` and choose `-DCMAKE_BUILD_TYPE` at configure time.

# End of .clinerules